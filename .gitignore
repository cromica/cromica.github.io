# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Phase 0 Ghost capture: keep manifests/plans tracked, keep raw backups local
migration-data/phase0/raw/**
!migration-data/phase0/raw/.gitkeep
!migration-data/phase0/raw/*/
!migration-data/phase0/raw/*/.gitkeep
migration-data/phase0/logs/**
!migration-data/phase0/logs/.gitkeep

# Hugo build output
public/
resources/_gen/
.hugo_build.lock
